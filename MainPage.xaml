<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Playlist_Builder.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#121212"
             Padding="10, 0, 10, 2">
			 
    <ContentPage.Content>
        <Grid RowDefinitions="Auto, *" RowSpacing="10">
            <!-- Üst Buton -->
            <Button Text="Çalma Listesi Oluştur"
                    BackgroundColor="#8A2BE2"
                    TextColor="White"
                    CornerRadius="12"
                    Padding="15,10"
                    HorizontalOptions="Center"
                    Clicked="CreatePlaylistButton_Clicked"/>

            <!-- Playlist CollectionView -->
            <CollectionView x:Name="PlaylistCollectionView"
                            ItemsSource="{Binding Playlists}"
                            SelectionMode="None"
                            Grid.Row="1">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="10"
                                     VerticalItemSpacing="10"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#1E1E1E" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPlaylistTapped"/>
                            </Border.GestureRecognizers>
                            <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                                <Label Text="{Binding Icon}" FontSize="24" HorizontalOptions="Center"/>
                                <Label Text="{Binding Name}" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center"/>
                                <Label Text="{Binding TotalSongs, StringFormat='{0} şarkı'}" TextColor="Gray" FontSize="12" HorizontalOptions="Center"/>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ContentPage.Content>
    
</ContentPage>
