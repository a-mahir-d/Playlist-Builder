<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Playlist_Builder.CreatePlaylistPage"
             BackgroundColor="#121212">
    
    <ContentPage.Content>
        <StackLayout Padding="20" Spacing="15">
            <Label Text="Çalma Listesi İsmi" TextColor="White"/>
            <Entry x:Name="PlaylistNameEntry" Placeholder="İsim girin" TextColor="White"/>

            <Label Text="Icon seçin" TextColor="White"/>
            <Picker x:Name="IconPicker" Title="Icon seçin">
                <Picker.Items>
                    <x:String>🎵</x:String>
                    <x:String>🎧</x:String>
                    <x:String>🚗</x:String>
                    <x:String>🔛</x:String>
                    <x:String>🎷</x:String>
                    <x:String>🎻</x:String>
                    <x:String>🎼</x:String>
                </Picker.Items>
            </Picker>

            <Grid x:Name="DownloadFolderGrid"
                  IsVisible="False"
                  ColumnSpacing="10"
                  HorizontalOptions="Fill">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Entry x:Name="DownloadFolderEntry"
                       Placeholder="İndirme klasör yolu"
                       IsReadOnly="True"
                       TextColor="White"
                       Grid.Column="0"/>

                <Button Text="Seç"
                        Clicked="PickFolderButton_Clicked"
                        BackgroundColor="#8A2BE2"
                        TextColor="White"
                        x:Name="PickFolderButton"
                        Grid.Column="1"/>
            </Grid>

            <Button Text="Kaydet" Clicked="SaveButton_Clicked" BackgroundColor="#1DB954" TextColor="White" CornerRadius="10"/>
            <Button Text="İptal" Clicked="CancelButton_Clicked" BackgroundColor="#8A2BE2" TextColor="White" CornerRadius="10"/>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>